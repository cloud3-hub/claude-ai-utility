  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(node --version)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bench *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(docker ps)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(psql *)",
      "Bash(mariadb *)",
      "Bash(redis-cli ping)",
      "Bash(brew services list)",
